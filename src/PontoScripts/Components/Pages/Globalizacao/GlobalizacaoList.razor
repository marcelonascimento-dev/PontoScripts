@page "/globalizacao"
@rendermode InteractiveServer
@inject GlobalizacaoService GlobService
@inject NavigationManager Nav

<PageTitle>Globalização - PontoScripts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Globalização</h3>
    <div class="d-flex gap-2">
        <label class="btn btn-outline-info mb-0">
            <i class="bi bi-upload me-1"></i>Importar JSON
            <InputFile OnChange="ImportarAsync" accept=".json" style="display:none" />
        </label>
        <a href="globalizacao/novo" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Nova Entrada
        </a>
    </div>
</div>

@if (importMsg is not null)
{
    <div class="alert @(importErro ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @importMsg
        <button type="button" class="btn-close" @onclick="() => importMsg = null"></button>
    </div>
}

@if (entries is null)
{
    <div class="text-center p-5"><span class="spinner-border"></span></div>
}
else if (entries.Count == 0)
{
    <div class="alert alert-info">Nenhuma entrada de globalização cadastrada.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Tipo</th>
                    <th>Mensagem</th>
                    <th>pt-BR</th>
                    <th>en-US</th>
                    <th>es-ES</th>
                    <th style="width: 100px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    <tr>
                        <td><small>@e.Tipo</small></td>
                        <td><strong>@e.Mensagem</strong></td>
                        <td><small>@Truncar(e.TraducaoPtBR)</small></td>
                        <td><small>@Truncar(e.TraducaoEnUS)</small></td>
                        <td><small>@Truncar(e.TraducaoEsES)</small></td>
                        <td>
                            <a href="globalizacao/@e.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ExcluirAsync(e)"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<GlobalizacaoEntry>? entries;
    private string? importMsg;
    private bool importErro;

    protected override async Task OnInitializedAsync()
    {
        entries = await GlobService.ListarAsync();
    }

    private async Task ExcluirAsync(GlobalizacaoEntry entry)
    {
        await GlobService.ExcluirAsync(entry.Id);
        entries = await GlobService.ListarAsync();
    }

    private async Task ImportarAsync(InputFileChangeEventArgs e)
    {
        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            content.Add(new StreamContent(ms), "arquivo", e.File.Name);

            using var http = new HttpClient();
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var response = await http.PostAsync($"{baseUri}/api/import/globalizacao", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ImportResultDto>();
                importMsg = $"Importação concluída: {result?.Importados ?? 0} importados, {result?.Ignorados ?? 0} ignorados (duplicados).";
                importErro = false;
                entries = await GlobService.ListarAsync();
            }
            else
            {
                importMsg = "Erro ao importar arquivo.";
                importErro = true;
            }
        }
        catch (Exception ex)
        {
            importMsg = $"Erro: {ex.Message}";
            importErro = true;
        }
    }

    private record ImportResultDto(int Importados, int Ignorados, List<string>? Erros);

    private string Truncar(string texto, int max = 30)
    {
        if (string.IsNullOrEmpty(texto)) return "";
        return texto.Length <= max ? texto : texto[..max] + "...";
    }
}
