@page "/versoes"
@rendermode InteractiveServer
@inject VersaoService VersaoService
@inject IJSRuntime JS

<PageTitle>Versões - PontoScripts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Versões</h3>
    <a href="versoes/criar" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>Nova Versão
    </a>
</div>

@if (versoes is null)
{
    <div class="text-center p-5"><span class="spinner-border"></span></div>
}
else if (versoes.Count == 0)
{
    <div class="alert alert-info">Nenhuma versão criada.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover bg-white">
            <thead class="table-dark">
                <tr>
                    <th>Versão</th>
                    <th>Data de Criação</th>
                    <th>Data de Geração</th>
                    <th>Status</th>
                    <th>Globalizações</th>
                    <th>Scripts</th>
                    <th style="width: 150px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var v in versoes)
                {
                    <tr>
                        <td><strong>@v.Numero</strong></td>
                        <td>@v.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@(v.DataGeracao?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td><span class="badge @GetStatusBadge(v.Status)">@v.Status</span></td>
                        <td>@v.VersaoGlobalizacoes.Count</td>
                        <td>@v.VersaoScripts.Count</td>
                        <td>
                            <a href="versoes/@v.Id" class="btn btn-sm btn-outline-primary me-1" title="Preview">
                                <i class="bi bi-eye"></i>
                            </a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmarExclusaoAsync(v)" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (versaoParaExcluir is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar Exclusão</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelarExclusao"></button>
                </div>
                <div class="modal-body">
                    <p>Deseja realmente excluir a versão <strong>@versaoParaExcluir.Numero</strong>?</p>
                    <p class="mb-0 text-muted">
                        <i class="bi bi-info-circle me-1"></i>
                        Os scripts e globalizações vinculados serão liberados e voltarão ao status <strong>Pendente</strong>.
                    </p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelarExclusao">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ExcluirAsync">
                        <i class="bi bi-trash me-1"></i>Excluir Versão
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Versao>? versoes;
    private Versao? versaoParaExcluir;

    protected override async Task OnInitializedAsync()
    {
        versoes = await VersaoService.ListarAsync();
    }

    private void ConfirmarExclusaoAsync(Versao versao)
    {
        versaoParaExcluir = versao;
    }

    private void CancelarExclusao()
    {
        versaoParaExcluir = null;
    }

    private async Task ExcluirAsync()
    {
        if (versaoParaExcluir is null) return;
        await VersaoService.ExcluirAsync(versaoParaExcluir.Id);
        versaoParaExcluir = null;
        versoes = await VersaoService.ListarAsync();
    }

    private string GetStatusBadge(StatusVersao status) => status switch
    {
        StatusVersao.Aberta => "bg-warning text-dark",
        StatusVersao.Gerada => "bg-info",
        StatusVersao.Liberada => "bg-success",
        _ => "bg-secondary"
    };
}
