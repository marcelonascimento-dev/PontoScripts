@page "/"
@rendermode InteractiveServer
@inject GlobalizacaoService GlobService
@inject VersaoService VersaoService
@inject ScriptAlteracaoService ScriptService

<PageTitle>Dashboard - PontoScripts</PageTitle>

<h3 class="mb-4">Dashboard</h3>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h2 class="text-primary">@globPendentes</h2>
                <p class="text-muted mb-0">Globalizações Pendentes</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-secondary">
            <div class="card-body text-center">
                <h2 class="text-secondary">@scriptsPendentes</h2>
                <p class="text-muted mb-0">Scripts Pendentes</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-success">
            <div class="card-body text-center">
                <a href="versoes/criar" class="btn btn-success btn-lg">
                    <i class="bi bi-plus-circle me-2"></i>Nova Versão
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Globalizações Pendentes</h5>
                <a href="globalizacao/novo" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus me-1"></i>Nova Globalização
                </a>
            </div>
            <div class="card-body p-0">
                @if (pendentes is null)
                {
                    <div class="p-3 text-center"><span class="spinner-border spinner-border-sm"></span> Carregando...</div>
                }
                else if (pendentes.Count == 0)
                {
                    <div class="p-3 text-center text-muted">Nenhuma globalização pendente.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var g in pendentes.Take(10))
                        {
                            <a href="globalizacao/@g.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@g.Tipo</strong>
                                    <small class="text-muted ms-2">@g.Mensagem</small>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">Versões Recentes</h5>
            </div>
            <div class="card-body p-0">
                @if (versoes is null)
                {
                    <div class="p-3 text-center"><span class="spinner-border spinner-border-sm"></span> Carregando...</div>
                }
                else if (versoes.Count == 0)
                {
                    <div class="p-3 text-center text-muted">Nenhuma versão criada.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var v in versoes.Take(10))
                        {
                            <a href="versoes/@v.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@v.Numero</strong>
                                    <small class="text-muted ms-2">@v.DataCriacao.ToString("dd/MM/yyyy")</small>
                                </div>
                                <span class="badge @GetStatusBadge(v.Status)">@v.Status</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int globPendentes;
    private int scriptsPendentes;
    private List<GlobalizacaoEntry>? pendentes;
    private List<Versao>? versoes;

    protected override async Task OnInitializedAsync()
    {
        globPendentes = await GlobService.ContarPendentesAsync();
        scriptsPendentes = await ScriptService.ContarPendentesAsync();
        pendentes = await GlobService.ListarPendentesAsync();
        versoes = await VersaoService.ListarAsync();
    }

    private string GetStatusBadge(StatusVersao status) => status switch
    {
        StatusVersao.Aberta => "bg-warning text-dark",
        StatusVersao.Gerada => "bg-info",
        StatusVersao.Liberada => "bg-success",
        _ => "bg-secondary"
    };
}
