@page "/"
@rendermode InteractiveServer
@inject GlobalizacaoService GlobService
@inject VersaoService VersaoService
@inject ScriptAlteracaoService ScriptService

<PageTitle>Dashboard - PontoScripts</PageTitle>

<h3 class="mb-4">Dashboard</h3>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-primary h-100">
            <div class="card-body text-center">
                <h2 class="text-primary">@globPendentes</h2>
                <p class="text-muted mb-0">Globalizações Pendentes</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-secondary h-100">
            <div class="card-body text-center">
                <h2 class="text-secondary">@scriptsPendentes</h2>
                <p class="text-muted mb-0">Scripts Pendentes</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-info h-100">
            <div class="card-body text-center">
                <h2 class="text-info">@totalVersoes</h2>
                <p class="text-muted mb-0">Versões Criadas</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-activity me-2"></i>Atividade Recente</h5>
            </div>
            <div class="card-body p-0">
                @if (atividades is null)
                {
                    <div class="p-3 text-center"><span class="spinner-border spinner-border-sm"></span></div>
                }
                else if (atividades.Count == 0)
                {
                    <div class="p-3 text-center text-muted">Nenhuma atividade registrada.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var a in atividades)
                        {
                            <a href="@a.Link" class="list-group-item list-group-item-action">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <span class="badge @a.BadgeCss me-2">@a.Tipo</span>
                                        <strong>@a.Titulo</strong>
                                        @if (!string.IsNullOrEmpty(a.Detalhe))
                                        {
                                            <br /><small class="text-muted">@a.Detalhe</small>
                                        }
                                    </div>
                                    <small class="text-muted text-nowrap ms-2">@a.DataRelativa</small>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-tags me-2"></i>Versões Recentes</h5>
            </div>
            <div class="card-body p-0">
                @if (versoes is null)
                {
                    <div class="p-3 text-center"><span class="spinner-border spinner-border-sm"></span></div>
                }
                else if (versoes.Count == 0)
                {
                    <div class="p-3 text-center text-muted">Nenhuma versão criada.</div>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var v in versoes.Take(10))
                        {
                            <a href="versoes/@v.Id" class="list-group-item list-group-item-action">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@v.Numero</strong>
                                        <small class="text-muted ms-2">@v.DataCriacao.ToString("dd/MM/yyyy")</small>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <small class="text-muted">
                                            <i class="bi bi-translate me-1"></i>@v.VersaoGlobalizacoes.Count
                                            <i class="bi bi-file-earmark-code ms-2 me-1"></i>@v.VersaoScripts.Count
                                        </small>
                                        <span class="badge @GetStatusBadge(v.Status)">@v.Status</span>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int globPendentes;
    private int scriptsPendentes;
    private int totalVersoes;
    private List<AtividadeItem>? atividades;
    private List<Versao>? versoes;

    protected override async Task OnInitializedAsync()
    {
        globPendentes = await GlobService.ContarPendentesAsync();
        scriptsPendentes = await ScriptService.ContarPendentesAsync();
        versoes = await VersaoService.ListarAsync();
        totalVersoes = versoes.Count;

        var items = new List<AtividadeItem>();

        var globs = await GlobService.ListarAsync();
        foreach (var g in globs)
        {
            items.Add(new AtividadeItem
            {
                Tipo = "Globalização",
                BadgeCss = "bg-primary",
                Titulo = $"{g.Tipo} — {g.Mensagem}",
                Detalhe = !string.IsNullOrEmpty(g.Branch) ? $"\u2192 {g.Branch}" : null,
                Data = g.DataCriacao,
                Link = $"globalizacao/{g.Id}"
            });
        }

        var scripts = await ScriptService.ListarAsync();
        foreach (var s in scripts)
        {
            items.Add(new AtividadeItem
            {
                Tipo = "Script",
                BadgeCss = "bg-secondary",
                Titulo = s.Descricao,
                Detalhe = !string.IsNullOrEmpty(s.Branch) ? $"{s.CriadoPor} \u2192 {s.Branch}" : s.CriadoPor,
                Data = s.DataCriacao,
                Link = $"scripts/{s.Id}"
            });
        }

        atividades = items.OrderByDescending(a => a.Data).Take(15).ToList();
    }

    private string GetStatusBadge(StatusVersao status) => status switch
    {
        StatusVersao.Aberta => "bg-warning text-dark",
        StatusVersao.Gerada => "bg-info",
        StatusVersao.Liberada => "bg-success",
        _ => "bg-secondary"
    };

    private class AtividadeItem
    {
        public string Tipo { get; set; } = "";
        public string BadgeCss { get; set; } = "";
        public string Titulo { get; set; } = "";
        public string? Detalhe { get; set; }
        public DateTime Data { get; set; }
        public string Link { get; set; } = "";

        public string DataRelativa
        {
            get
            {
                var diff = DateTime.Now - Data;
                if (diff.TotalMinutes < 1) return "agora";
                if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}min";
                if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h";
                if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d";
                return Data.ToString("dd/MM");
            }
        }
    }
}
