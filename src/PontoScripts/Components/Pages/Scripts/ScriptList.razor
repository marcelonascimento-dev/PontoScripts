@page "/scripts"
@rendermode InteractiveServer
@inject ScriptAlteracaoService ScriptService
@inject NavigationManager Nav

<PageTitle>Scripts - PontoScripts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Scripts de Alteração</h3>
    <div class="d-flex gap-2">
        <label class="btn btn-outline-info mb-0">
            <i class="bi bi-upload me-1"></i>Importar JSON
            <InputFile OnChange="ImportarAsync" accept=".json" style="display:none" />
        </label>
        <a href="scripts/novo" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Novo Script
        </a>
    </div>
</div>

@if (importMsg is not null)
{
    <div class="alert @(importErro ? "alert-danger" : "alert-success") alert-dismissible fade show">
        @importMsg
        <button type="button" class="btn-close" @onclick="() => importMsg = null"></button>
    </div>
}

<div class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input type="text" class="form-control" placeholder="Buscar por OS, descrição ou branch..." @bind="busca" @bind:event="oninput" @bind:after="FiltrarAsync" />
    </div>
</div>

@if (entries is null)
{
    <div class="text-center p-5"><span class="spinner-border"></span></div>
}
else if (entries.Count == 0)
{
    <div class="alert alert-info">Nenhum script cadastrado.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover bg-white">
            <thead class="table-dark">
                <tr>
                    <th style="width: 60px;">Ordem</th>
                    <th>OS</th>
                    <th>Branch</th>
                    <th>Descrição</th>
                    <th>Criado Por</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th style="width: 140px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in entries)
                {
                    var versionado = e.VersaoScripts.Any();
                    <tr>
                        <td class="text-center">@e.OrdemExecucao</td>
                        <td>@(e.NumeroOS ?? "-")</td>
                        <td><small class="text-muted">@(e.Branch ?? "-")</small></td>
                        <td>@e.Descricao</td>
                        <td>@e.CriadoPor</td>
                        <td>@e.DataCriacao.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (versionado)
                            {
                                <span class="badge bg-success">Versionado</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pendente</span>
                            }
                        </td>
                        <td>
                            @if (!versionado)
                            {
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MoverAsync(e, -1)" title="Mover para cima" disabled="@(!PodeMover(e, -1))">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => MoverAsync(e, 1)" title="Mover para baixo" disabled="@(!PodeMover(e, 1))">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                            }
                            <a href="scripts/@e.Id" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ExcluirAsync(e)"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<ScriptAlteracaoEntry>? entries;
    private string busca = "";
    private string? importMsg;
    private bool importErro;

    protected override async Task OnInitializedAsync()
    {
        entries = await ScriptService.ListarAsync();
    }

    private async Task FiltrarAsync()
    {
        entries = await ScriptService.ListarAsync(string.IsNullOrWhiteSpace(busca) ? null : busca);
    }

    private bool PodeMover(ScriptAlteracaoEntry entry, int direcao)
    {
        if (entries is null) return false;
        var pendentes = entries.Where(e => !e.VersaoScripts.Any()).ToList();
        var idx = pendentes.IndexOf(entry);
        if (idx < 0) return false;
        return direcao == -1 ? idx > 0 : idx < pendentes.Count - 1;
    }

    private async Task MoverAsync(ScriptAlteracaoEntry entry, int direcao)
    {
        if (entries is null) return;
        var pendentes = entries.Where(e => !e.VersaoScripts.Any()).OrderBy(e => e.OrdemExecucao).ToList();
        var idx = pendentes.IndexOf(entry);
        var novoIdx = idx + direcao;
        if (novoIdx < 0 || novoIdx >= pendentes.Count) return;

        var outro = pendentes[novoIdx];
        (entry.OrdemExecucao, outro.OrdemExecucao) = (outro.OrdemExecucao, entry.OrdemExecucao);

        await ScriptService.AtualizarAsync(entry);
        await ScriptService.AtualizarAsync(outro);
        entries = await ScriptService.ListarAsync(string.IsNullOrWhiteSpace(busca) ? null : busca);
    }

    private async Task ExcluirAsync(ScriptAlteracaoEntry entry)
    {
        await ScriptService.ExcluirAsync(entry.Id);
        entries = await ScriptService.ListarAsync(string.IsNullOrWhiteSpace(busca) ? null : busca);
    }

    private async Task ImportarAsync(InputFileChangeEventArgs e)
    {
        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;
            content.Add(new StreamContent(ms), "arquivo", e.File.Name);

            using var http = new HttpClient();
            var baseUri = Nav.BaseUri.TrimEnd('/');
            var response = await http.PostAsync($"{baseUri}/api/import/scripts", content);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ImportResultDto>();
                importMsg = $"Importação concluída: {result?.Importados ?? 0} importados, {result?.Ignorados ?? 0} ignorados.";
                importErro = false;
                entries = await ScriptService.ListarAsync();
            }
            else
            {
                importMsg = "Erro ao importar arquivo.";
                importErro = true;
            }
        }
        catch (Exception ex)
        {
            importMsg = $"Erro: {ex.Message}";
            importErro = true;
        }
    }

    private record ImportResultDto(int Importados, int Ignorados, List<string>? Erros);
}
